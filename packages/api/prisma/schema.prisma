// Prisma schema for the task board.
// Some intentional design choices here are part of the planted bugs in this
// interview practice repo — see BUGS.md for details.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  tasks Task[] @relation("AssignedTasks")
}

model Board {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  columns Column[]
}

model Column {
  id      String @id @default(cuid())
  name    String
  // Position of the column within its board (lower = leftmost).
  // Stored as Int — kept consistent so column ordering "just works".
  position Int

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([boardId, position])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  // BUG: position is stored as a String instead of an Int. The original
  // intent was to support fractional re-ordering ("a0", "a5", "b3"-style
  // keys) but the implementation never landed, and now tasks sort
  // lexicographically — "10" sorts before "2". See BUGS.md #3.
  position    String    @default("0")
  dueDate     DateTime?
  priority    Priority  @default(MEDIUM)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([columnId])
  @@index([assigneeId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
