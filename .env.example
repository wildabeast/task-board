# Copy this file to .env and adjust as needed.
# Used by Docker Compose, the API server, and the web client.

# --- Postgres (consumed by docker-compose.yml) ---
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=taskboard
POSTGRES_DB=taskboard
POSTGRES_PORT=5432

# --- API ---
# Prisma reads DATABASE_URL.
DATABASE_URL=postgresql://taskboard:taskboard@localhost:5432/taskboard?schema=public
API_PORT=4000

# --- Web ---
# Vite picks this up at build/dev time.
VITE_GRAPHQL_URL=http://localhost:4000/graphql
WEB_PORT=5173
