{
  "name": "task-board-interview-practice",
  "private": true,
  "packageManager": "yarn@4.5.3",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait postgres && yarn workspace @taskboard/api db:push && yarn workspace @taskboard/api db:seed",
    "db:push": "yarn workspace @taskboard/api db:push",
    "db:seed": "yarn workspace @taskboard/api db:seed",
    "dev:api": "yarn workspace @taskboard/api dev",
    "dev:web": "yarn workspace @taskboard/web dev",
    "dev": "concurrently -n api,web -c blue,green \"yarn dev:api\" \"yarn dev:web\"",
    "build": "yarn workspaces foreach -A run build",
    "lint": "yarn workspaces foreach -A run lint",
    "typecheck": "yarn workspaces foreach -A run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
